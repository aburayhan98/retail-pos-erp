@page "/sales"
@rendermode InteractiveServer
@using RetailErp.Pos.Application.DTOs.Products
@using RetailErp.Pos.Application.DTOs.Sales
@using RetailErp.Pos.UI.Services
@inject PosApiService PosApiService

<h3 class="mb-3">Create Sale</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
  <div class="alert alert-danger">@errorMessage</div>
}

<div class="card mb-4">
  <div class="card-body">

    <div class="row g-3 mb-3">
      <div class="col-md-4">
        <label class="form-label">Product</label>
        <select class="form-select" @bind="selectedProductId">
          <option value="">-- Select Product --</option>
          @foreach (var product in products)
          {
            <option value="@product.ProductId">@product.Name</option>
          }
        </select>
      </div>

      <div class="col-md-2">
        <label class="form-label">Quantity</label>
        <InputNumber class="form-control" @bind-Value="quantity" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Price</label>
        <InputNumber class="form-control" @bind-Value="unitPrice" />
      </div>

      <div class="col-md-2">
        <label class="form-label">Barcode</label>
        <InputText class="form-control" @bind-Value="barcode" />
      </div>

      <div class="col-md-2 d-flex align-items-end">
        <button type="button" class="btn btn-success w-100" @onclick="AddItem">
          Add
        </button>
      </div>
    </div>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Product</th>
          <th>Qty</th>
          <th>Price</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var item in items)
        {
          <tr>
            <td>@item.ProductName</td>
            <td>@item.Quantity</td>
            <td>@item.UnitPrice</td>
            <td>@(item.Quantity* item.UnitPrice)</td>
          </tr>
        }
      </tbody>
    </table>

    <div class="mt-3">
      <strong>Total: @totalAmount</strong>
    </div>

    <div class="mt-3">
      <button type="button" class="btn btn-primary" @onclick="CreateSale" disabled="@isSaving">
        @(isSaving ? "Processing..." : "Create Sale")
      </button>
    </div>

  </div>
</div>

@code {
  private List<ProductResponse> products = new();
  private List<SaleItemUI> items = new();

  private Guid selectedProductId;
  private int quantity = 1;
  private decimal unitPrice;
  private string barcode = string.Empty;

  private decimal totalAmount => items.Sum(x => x.Quantity * x.UnitPrice);

  private bool isSaving = false;
  private string errorMessage = string.Empty;

  protected override async Task OnInitializedAsync()
  {
    products = await PosApiService.GetProductsAsync();
  }

  private void AddItem()
  {
    var product = products.FirstOrDefault(p => p.ProductId == selectedProductId);

    if (product == null)
    {
      errorMessage = "Select a product";
      return;
    }

    if (quantity <= 0)
    {
      errorMessage = "Quantity must be greater than zero";
      return;
    }

    if (unitPrice <= 0)
    {
      errorMessage = "Price must be greater than zero";
      return;
    }

    var existingItem = items.FirstOrDefault(x =>
        x.ProductId == product.ProductId &&
        x.UnitPrice == unitPrice &&
        x.Barcode == barcode);

    if (existingItem is not null)
    {
      existingItem.Quantity += quantity;
    }
    else
    {
      items.Add(new SaleItemUI
      {
        ProductId = product.ProductId,
        ProductName = product.Name,
        Quantity = quantity,
        UnitPrice = unitPrice,
        Barcode = barcode
      });
    }

    errorMessage = string.Empty;
  }

  private async Task CreateSale()
  {
    try
    {
      isSaving = true;

      var request = new CreateSaleRequest
      {
        OutletId = Guid.NewGuid(), // simulate outlet
        Items = items.Select(x => new CreateSaleItemRequest
        {
          ProductId = x.ProductId,
          Quantity = x.Quantity,
          UnitPrice = x.UnitPrice,
          Barcode = x.Barcode
        }).ToList()
      };

      await PosApiService.CreateSaleAsync(request);

      items.Clear();
    }
    catch (Exception ex)
    {
      errorMessage = ex.Message;
    }
    finally
    {
      isSaving = false;
    }
  }

  private class SaleItemUI
  {
    public Guid ProductId { get; set; }
    public string ProductName { get; set; } = "";
    public int Quantity { get; set; }
    public decimal UnitPrice { get; set; }
    public string Barcode { get; set; } = "";
  }
}